{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "DeskOps Desktop",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "http": {
        "all": true,
        "request": true,
        "scope": ["http://localhost:4310/*"]
      },
      "path": {
        "all": true
      },
      "shell": {
        "all": true,
        "execute": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.deskops.desktop",
      "targets": "all"
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "DeskOps Desktop",
        "width": 1180,
        "height": 800,
        "resizable": true
      }
    ]
  }
}
