APP_NAME=deskops-backend
APP_ENV=local
APP_PORT=4310

# -----------------------------------------------------------------------------
# Database (Aurora/RDS PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/deskops
USE_IN_MEMORY_REPOSITORIES=true

# -----------------------------------------------------------------------------
# AWS / Bedrock (Nova Lite)
# Use either static credentials or AWS_PROFILE.
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me
AWS_SESSION_TOKEN=
AWS_PROFILE=
AWS_DEFAULT_REGION=us-east-1

AI_PROVIDER=bedrock_nova
AI_MODEL_ID=global.amazon.nova-2-lite-v1:0
AI_REGION=us-east-1
AI_METADATA_ONLY=true
AI_MAX_TOKENS=900
AI_TEMPERATURE=0.2
AI_TIMEOUT_SECONDS=20
AI_STARTUP_FAIL_FAST=false

# -----------------------------------------------------------------------------
# Worker / Startup Behavior
# -----------------------------------------------------------------------------
ENABLE_OUTBOX_DAEMON=false
OUTBOX_POLL_INTERVAL_SECONDS=5
OUTBOX_POLL_LIMIT=100
OUTBOX_MAX_ATTEMPTS=3
DB_STARTUP_CHECK_ENABLED=true
DB_STARTUP_FAIL_FAST=true
